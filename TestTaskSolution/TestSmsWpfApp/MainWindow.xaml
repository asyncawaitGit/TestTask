<Window x:Class="TestSmsWpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestSmsWpfApp"
        mc:Ignorable="d"
        Title="MainWindow" 
        Height="450" 
        Width="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="White"
            CornerRadius="20"
            Margin="0"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid Margin="10">
            <DataGrid x:Name="VariablesDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" FocusVisualStyle="{x:Null}" >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Поле" Binding="{Binding Name}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Значение" Binding="{Binding Value}"/>
                    <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}"/>
                </DataGrid.Columns>
            </DataGrid>
            <Button Content="Сохранить" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="100"
                Margin="0,0,0,10" />
        </Grid>
    </Border>
</Window>
